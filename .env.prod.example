# ── Database ─────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=stockpile
POSTGRES_USER=stockpile
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Redis ─────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── Auth ─────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_RANDOM_64_CHARS

# ── LLM Provider ─────────────────────────────────────────
# 'ollama': Ollama 로컬 LLM (비용 없음, 속도 느림)
# 'anthropic': Claude API (빠름, 비용 발생)
LLM_PROVIDER=groq
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.1-8b-instant
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:7b
EMBED_MODEL=nomic-embed-text

# ── AI / External APIs ────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
DART_API_KEY=...
NAVER_CLIENT_ID=...
NAVER_CLIENT_SECRET=...

# ── Frontend (Next.js build-time) ─────────────────────────
# 도메인이 example.com 이라면:
NEXT_PUBLIC_JOURNAL_URL=https://example.com/api/journal
NEXT_PUBLIC_REPORT_URL=https://example.com/api/report
