# ── Database ─────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=stockpile
POSTGRES_USER=stockpile
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Redis ─────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── AI / External APIs ────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
DART_API_KEY=...
NAVER_CLIENT_ID=...
NAVER_CLIENT_SECRET=...

# ── Frontend (Next.js build-time) ─────────────────────────
# 도메인이 example.com 이라면:
NEXT_PUBLIC_JOURNAL_URL=https://example.com/api/journal
NEXT_PUBLIC_REPORT_URL=https://example.com/api/report
