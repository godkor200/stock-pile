{
  "extends": "@stock-pile/tsconfig/nextjs.json",
  "compilerOptions": {
    "lib": ["ES2022", "dom", "dom.iterable"],
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "noEmit": true,
    "incremental": true,
    "isolatedModules": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
