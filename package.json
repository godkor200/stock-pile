{
  "name": "stock-pile",
  "private": true,
  "scripts": {
    "dev": "kill -9 $(lsof -ti :3001 :3002 :3005 2>/dev/null) 2>/dev/null; turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "db:migrate": "pnpm --filter db-schema migration:run",
    "db:migrate:generate": "pnpm --filter db-schema migration:generate"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "prettier": "^3.0.0",
    "turbo": "^2.0.0",
    "typescript": "^5.0.0"
  },
  "pnpm": {
    "overrides": {
      "multer": "^2.0.0"
    }
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
