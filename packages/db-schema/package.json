{
  "name": "@stock-pile/db-schema",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "migration:run": "typeorm-ts-node-commonjs migration:run -d src/data-source.ts",
    "migration:generate": "typeorm-ts-node-commonjs migration:generate -d src/data-source.ts",
    "migration:revert": "typeorm-ts-node-commonjs migration:revert -d src/data-source.ts",
    "seed:stocks": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' src/seeds/stocks.seed.ts"
  },
  "dependencies": {
    "@stock-pile/shared-types": "workspace:*",
    "typeorm": "^0.3.20",
    "pg": "^8.11.0",
    "reflect-metadata": "^0.2.0"
  },
  "devDependencies": {
    "@stock-pile/tsconfig": "workspace:*",
    "@types/pg": "^8.11.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  }
}
